# URL base del backend.
# Local sin Docker:    http://localhost:8000
# docker-compose:      http://localhost:8000 (el puerto se expone al host)
# Producción (Vercel): https://tu-backend.up.railway.app
VITE_API_URL=http://localhost:8000

# Muestra la opción "Soy admin" en el modal de registro.
# En producción ponla en false (o no la definas) para ocultarla.
# En dev se muestra igualmente porque import.meta.env.DEV es true.
VITE_ENABLE_ADMIN_REGISTER=false
