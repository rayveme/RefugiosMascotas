# ============================================================
# Variables que consume docker-compose.yml.
# Copia a `.env` en la raíz (mismo nivel que docker-compose.yml) y completa.
# ============================================================

# --- Postgres (compose crea el contenedor con estos valores) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=refugios

# --- Backend ---
APP_NAME=RefugiosMascotas API
DEBUG=true
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=

JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

SESSION_SECRET=another-long-random-string

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Cloudinary (opcional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=huella/pets

# --- Frontend ---
VITE_API_URL=http://localhost:8000
