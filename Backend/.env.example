# ============================================================
# Backend env — copia este archivo a `.env` y completa los valores.
# `.env` está en .gitignore, NO commitearlo.
# ============================================================

# --- App ---
APP_NAME=RefugiosMascotas API
DEBUG=true
FRONTEND_URL=http://localhost:5173

# CORS: lista separada por comas. Útil para añadir el dominio de Vercel.
# Si lo dejas vacío, se permiten los hosts típicos de Vite + FRONTEND_URL.
# Ej en producción: CORS_ORIGINS=https://mi-app.vercel.app,http://localhost:5173
CORS_ORIGINS=

# --- Postgres async ---
# Local sin Docker:       postgresql+asyncpg://postgres:postgres@localhost:5432/refugios
# docker-compose (red):   postgresql+asyncpg://postgres:postgres@db:5432/refugios
# Railway:                la inyecta el plugin de Postgres como DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/refugios

# --- JWT ---
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Sesión OAuth (state Authlib) ---
SESSION_SECRET=another-long-random-string

# --- Google OAuth (opcional, deja vacío si no usas login con Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Cloudinary (opcional, deja vacío si no subes imágenes) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=huella/pets
