# ============================================================
# Variables de entorno para PRODUCCIÓN (VPS + Docker)
# En el VPS: cp Backend/.env.prod.example Backend/.env
# Solo falta rellenar las dos líneas marcadas con ← PENDIENTE
# ============================================================

# --- App ---
APP_NAME=RefugiosMascotas API
DEBUG=false

# ← PENDIENTE: reemplaza con la URL exacta que te dé Vercel al hacer deploy
FRONTEND_URL=https://tu-app.vercel.app
CORS_ORIGINS=https://tu-app.vercel.app

# --- Postgres (docker-compose.prod.yml usa estas vars) ---
POSTGRES_USER=refugios
# ← PENDIENTE: pon una contraseña larga para la base de datos
POSTGRES_PASSWORD=CAMBIA_contraseña_larga_para_la_bd
POSTGRES_DB=refugios
# La URL interna de Docker apunta al servicio "db" — no cambies el host
DATABASE_URL=postgresql+asyncpg://refugios:CAMBIA_contraseña_larga_para_la_bd@db:5432/refugios

# --- JWT (ya generados) ---
JWT_SECRET=8bcede104c6e543927348d341e2a769eec8ed8862c371e63eacedd5c021f15dd
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Sesión OAuth (ya generado) ---
